# ══════════════════════════════════════════════════════════════════
# Gold Bot v2 – Environment Variables
# cp .env.example .env   →   then fill in your real values
# ══════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────────
TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
ADMIN_ID=123456789
CHANNEL_USERNAME=@my_jewelry_channel

# ── Groq AI ───────────────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Text model (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# Vision model for image search (default: meta-llama/llama-4-scout-17b-16e-instruct)
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Google Sheets ─────────────────────────────────────────────────
SPREADSHEET_NAME=Gold Products
# SERVICE_ACCOUNT_FILE=service_account.json

# ── App Settings ──────────────────────────────────────────────────
LOG_LEVEL=INFO
CACHE_TIME=300
# CONV_TTL=3600
# ADMIN_TTL=1800
# MAX_SEARCH_RESULTS=10
# CONV_HISTORY_PAIRS=10

# ── Automatic Gold Price Update ────────────────────────────────────
# How often (in seconds) the bot automatically scrapes tgju.org and
# updates the gold price in Google Sheets.
# 3600 = every 1 hour (recommended)
# 7200 = every 2 hours
# 0    = disabled (update manually via admin panel or update_price.py)
PRICE_UPDATE_INTERVAL=3600
