# ══════════════════════════════════════════════════════════════════
# Gold Bot v2 – Environment Variables
# cp .env.example .env   →   then fill in your real values
# ══════════════════════════════════════════════════════════════════

# ── Telegram ──────────────────────────────────────────────────────
TOKEN=1234567890:ABCdefGHIjklMNOpqrSTUvwxYZ
ADMIN_ID=123456789
CHANNEL_USERNAME=@my_jewelry_channel

# ── Deployment (Webhook / Render) ─────────────────────────────────
# Set WEBHOOK_URL to your Render service URL to enable webhook mode.
# Leave empty (or remove the line) to use polling mode locally.
#
# Render URL format: https://<your-service-name>.onrender.com
# (no trailing slash)
WEBHOOK_URL=https://my-gold-bot.onrender.com

# PORT is set automatically by Render — do NOT set it manually on Render.
# Only set it locally if you want a specific port for testing.
# PORT=8443

# Optional: a random secret that Telegram signs each webhook update with.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
# WEBHOOK_SECRET=

# ══════════════════════════════════════════════════════════════════
# AI Provider — provider-independent architecture (see providers/)
# Switching providers requires changing ONLY the AI_PROVIDER line below.
# ══════════════════════════════════════════════════════════════════
AI_PROVIDER=groq

# General AI behaviour (applies to whichever provider is active)
# AI_TEMPERATURE=0.7
# AI_MAX_TOKENS=1500
# AI_RETRY_COUNT=1
# AI_TIMEOUT=30

# ── Groq (default, fully implemented) ──────────────────────────────
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Gemini (skeleton — implement providers/gemini_provider.py to use) ─
# AI_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-1.5-flash
# GEMINI_VISION_MODEL=gemini-1.5-flash

# ── OpenAI (skeleton — implement providers/openai_provider.py to use) ─
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# ── Conversation Memory (Recent Messages + rolling Summary) ────────
# RECENT_MESSAGES_COUNT=6
# SUMMARY_TRIGGER_MESSAGES=6
# SUMMARY_MAX_CHARS=500

# ── Follow-up / Notifications ──────────────────────────────────────
# Similarity score (0..1) required for a restocked product to trigger
# an automatic notification to a customer.
# NOTIFICATION_SIMILARITY_THRESHOLD=0.55

# ── Google Sheets ─────────────────────────────────────────────────
SPREADSHEET_NAME=Gold Products
# SERVICE_ACCOUNT_FILE=service_account.json

# ── App Settings ──────────────────────────────────────────────────
LOG_LEVEL=INFO
CACHE_TIME=300
# CONV_TTL=3600
# ADMIN_TTL=1800
# MAX_SEARCH_RESULTS=10

# ── Automatic Gold Price Update ────────────────────────────────────
# How often (in seconds) the bot automatically scrapes tgju.org and
# updates the gold price in Google Sheets.
# 3600 = every 1 hour (recommended)
# 7200 = every 2 hours
# 0    = disabled (update manually via admin panel or update_price.py)
PRICE_UPDATE_INTERVAL=3600
